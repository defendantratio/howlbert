DISCORD_TOKEN=your_bot_token_here
BOT_DISPLAY_NAME=Howlbert
# Comma-separated server IDs for instant slash sync (leave empty for global ~1h delay)
TEST_GUILD_IDS=
ADMIN_IDS=
STATUS_CHANNEL_ID=
# Automatic daily sunrise (one per guild at this clock time)
AUTO_ROLLOVER_ENABLED=false
# US Eastern (EST/EDT); sunrise at ROLLOVER_HOUR:MINUTE in this zone
ROLLOVER_TIMEZONE=America/New_York
ROLLOVER_HOUR=0
ROLLOVER_MINUTE=0
# DM sunrise/den news when bot starts after missing rollover (hours after ROLLOVER_HOUR:MINUTE)
ROLLOVER_STARTUP_DM_HOURS=8
# Optional channel for rollover embeds (else system/first writable channel)
AUTO_ROLLOVER_ANNOUNCE_CHANNEL_ID=
# Wolves age +1 moon only on matching real moon phase (new/half/full). Set false for every sunrise.
LUNAR_BIRTH_AGING=true
# `/proxy` typed-message proxying: enable "Message Content Intent" in the Developer Portal first,
# then set this true and restart. Server Administrator does NOT enable this for you.
ENABLE_MESSAGE_CONTENT_INTENT=false
# Cropped `/proxy avatar` uploads are posted here for Discord CDN URLs (or create #howlbert-avatars)
AVATAR_CACHE_CHANNEL_ID=
# Comma-separated channel IDs for sunrise RP ambience posts (season/weather/moon)
RP_AMBIENCE_CHANNEL_IDS=
# Auto-updating index of currently-open /scene threads; one edited message, refreshed on start/join/leave/end
OPEN_SCENES_CHANNEL_ID=
KOFI_VERIFICATION_TOKEN=
KOFI_WEBHOOK_PORT=8080
